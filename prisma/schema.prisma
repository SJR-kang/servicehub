generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SEEKER
  PROVIDER
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  AWAITING_PAYMENT
  PAID
  COMPLETED
  REJECTED
}

enum ConversationKind {
  GENERAL
  REQUEST
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  phone        String?
  role         UserRole
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  providerProfile ProviderProfile?
  seekerRequests   ServiceRequest[] @relation("SeekerRequests")
  providerRequests ServiceRequest[] @relation("ProviderRequests")
  sentMessages     Message[]        @relation("SentMessages")
  seekerConversations   Conversation[] @relation("SeekerConversations")
  providerConversations Conversation[] @relation("ProviderConversations")
}

model ProviderProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  service        String
  category       String
  priceLabel     String
  description    String
  fullDetail     String?
  location       String?
  availability   String?
  rating         Float    @default(5)
  avatarImg      String?
  evidenceImg    String?
  contactPhone   String?
  yearsExperience Int?
  languages      String[]
  credentials    String[] @default([])
  services       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceRequest {
  id                 String        @id @default(cuid())
  requestCode        String        @unique
  seekerId           String
  providerId         String
  serviceName        String
  priceAmount        Float?
  preferredDate      DateTime?
  preferredTime      String?
  location           String?
  budget             String?
  serviceDetails     String?
  status             RequestStatus @default(PENDING)
  paymentRequestedAt DateTime?
  paymentAmount      Float? // requested amount (AWAITING_PAYMENT) OR paid amount (PAID) for legacy clients
  paymentType        String?
  paymentConfirmedAt DateTime?
  amountPaid         Float?   @default(0)
  remainingBalance   Float?   @default(0)
  isFullyPaid        Boolean  @default(false)
  completedAt        DateTime?
  rejectionReason    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  seeker   User @relation("SeekerRequests", fields: [seekerId], references: [id], onDelete: Cascade)
  provider User @relation("ProviderRequests", fields: [providerId], references: [id], onDelete: Cascade)
  conversation Conversation?
}

model Conversation {
  id                 String           @id @default(cuid())
  kind               ConversationKind @default(GENERAL)
  requestId          String?          @unique
  seekerId           String
  providerId         String
  lastMessageAt      DateTime         @default(now())
  seekerLastReadAt   DateTime?
  providerLastReadAt DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  request  ServiceRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  seeker   User            @relation("SeekerConversations", fields: [seekerId], references: [id], onDelete: Cascade)
  provider User            @relation("ProviderConversations", fields: [providerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([seekerId, providerId, kind])
  @@index([seekerId, lastMessageAt])
  @@index([providerId, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

